# fleet-telemetry-bridge forwarder configuration
# Copy to .env next to docker-compose.yml, then fill in INGEST_TOKEN.

# Bearer token for POST /ingest/telemetry on the Worker.
# Must match the Worker's INGEST_TOKEN secret (or MCP_AUTH_TOKEN if INGEST_TOKEN
# is unset there):  cd tesla-cf-mcp-worker && npx wrangler secret put INGEST_TOKEN
INGEST_TOKEN=change-me

# Worker ingest endpoint (default already points at the deployed Worker).
INGEST_URL=https://tesla-cf-mcp-worker.adamcfield.workers.dev/ingest/telemetry

# How long to accumulate MQTT field updates before POSTing one batched event
# per VIN. 1000ms matches the 1s VehicleSpeed cadence: ~1 POST/sec while
# driving, ~0 while parked.
BATCH_MS=1000

# Bounded retry queue (events, i.e. one per VIN per batch window). Oldest are
# dropped beyond this. 5000 ~= 80+ min of driving-rate backlog if the Worker
# is unreachable.
MAX_QUEUE_EVENTS=5000

# Max events folded into a single POST when draining a backlog.
MAX_EVENTS_PER_POST=50

# Per-POST timeout.
POST_TIMEOUT_MS=10000

# true = log the exact JSON that would be POSTed instead of sending it
# (equivalent to `node index.js --dry-run`).
DRY_RUN=false

# --- fixed by docker-compose.yml; only set these when running the forwarder
# --- outside compose (e.g. `node forwarder/index.js --dry-run` on your laptop)
#MQTT_URL=mqtt://localhost:1883
#MQTT_TOPIC_BASE=telemetry
#MQTT_CLIENT_ID=ft-forwarder
