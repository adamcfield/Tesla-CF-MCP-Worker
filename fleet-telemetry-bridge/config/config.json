{
  "host": "0.0.0.0",
  "port": 8443,
  "status_port": 8080,
  "log_level": "info",
  "json_log_enable": true,
  "namespace": "tesla_telemetry",
  "monitoring": {
    "prometheus_metrics_port": 9090,
    "profiler_port": 4269,
    "profiling_path": "/tmp/trace.out"
  },
  "rate_limit": {
    "enabled": true,
    "message_interval_time": 30,
    "message_limit": 1000
  },
  "reliable_ack_sources": {
    "V": "mqtt"
  },
  "records": {
    "alerts": ["mqtt"],
    "errors": ["mqtt"],
    "V": ["mqtt"],
    "connectivity": ["mqtt"]
  },
  "mqtt": {
    "broker": "mosquitto:1883",
    "client_id": "fleet-telemetry",
    "topic_base": "telemetry",
    "qos": 1,
    "retained": false,
    "connect_timeout_ms": 30000,
    "publish_timeout_ms": 2500,
    "disconnect_timeout_ms": 250,
    "connect_retry_interval_ms": 10000,
    "keep_alive_seconds": 30
  },
  "tls": {
    "server_cert": "/etc/fleet-telemetry/certs/fullchain.pem",
    "server_key": "/etc/fleet-telemetry/certs/privkey.pem"
  }
}
